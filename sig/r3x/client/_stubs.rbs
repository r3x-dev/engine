module R3x
  module Client
    class Apify
      DEFAULT_API_KEY_ENV: String

      def initialize: (api_key: String api_key) -> void
    end

    class Discord
      DEFAULT_WEBHOOK_URL_ENV: String

      def initialize: (?webhook_url: String? webhook_url, ?webhook_url_env: String webhook_url_env) -> void
    end

    module Google
      class Gmail
        def initialize: (project: String project) -> void
      end

      class Translate
        def initialize: (project: String project) -> void
      end
    end

    class GoogleSheets
      def initialize: (spreadsheet_id: String spreadsheet_id, project: String project) -> void
    end

    class HealthchecksIO
      def initialize: (String check_uuid, ?ping_endpoint: String? ping_endpoint, ?ping_endpoint_env: String ping_endpoint_env) -> void
    end

    class Llm
      class ProviderConfiguration
        API_KEY_SUFFIX: String

        def self.resolve: (api_key_env: String api_key_env) -> R3x::Client::Llm::ProviderConfiguration

        def api_key: () -> String

        def config_api_key_attr: () -> String
      end

      module ProviderRegistry
        def self.register!: () -> void
      end

      module ModelRegistry
        def self.file_path: () -> Pathname
        def self.configure!: () -> void
        def self.read: () -> Array[untyped]
        def self.refresh!: () -> void
      end

      def initialize: (
        api_key: String api_key,
        config_api_key_attr: String config_api_key_attr,
        ?max_retries: Integer? max_retries,
        ?retry_interval: Numeric? retry_interval,
        ?retry_backoff_factor: Numeric? retry_backoff_factor
      ) -> void
    end

    class Markdownify
      def initialize: (url: String url, ?method: String method, ?retain_images: bool retain_images) -> void

      def convert: () -> Hash[String, String]
    end

    class Ocr
      DEFAULT_API_KEY_ENV: String

      def initialize: (?api_key_env: String api_key_env) -> void
    end

    class Prometheus
      DEFAULT_URL_ENV: String

      def initialize: (?url_env: String url_env) -> void
    end
  end
end

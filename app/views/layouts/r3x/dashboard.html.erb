<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for?(:title) ? yield(:title) : "R3x Dashboard" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <style>
      :root {
        color-scheme: light dark;
        --bg: #f5f7fb;
        --panel: #ffffff;
        --panel-strong: #f0f4ff;
        --line: #d8dfec;
        --text: #142033;
        --muted: #5d6b84;
        --ok-bg: #e8f8ef;
        --ok-text: #17643d;
        --info-bg: #e8f0ff;
        --info-text: #204a9f;
        --warn-bg: #fff3dc;
        --warn-text: #8a5a00;
        --danger-bg: #ffe6e3;
        --danger-text: #a1251c;
        --shadow: 0 20px 40px rgba(24, 39, 75, 0.08);
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #0d1117;
          --panel: #161c26;
          --panel-strong: #1d2633;
          --line: #2c394c;
          --text: #ecf2ff;
          --muted: #99a7bd;
          --ok-bg: #153827;
          --ok-text: #b4efcf;
          --info-bg: #1a305d;
          --info-text: #bfd2ff;
          --warn-bg: #4f3d10;
          --warn-text: #ffe0a3;
          --danger-bg: #4a1915;
          --danger-text: #ffb9b0;
          --shadow: 0 24px 48px rgba(0, 0, 0, 0.35);
        }
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }

      a {
        color: inherit;
      }

      .shell {
        max-width: 1200px;
        margin: 0 auto;
        padding: 24px 20px 56px;
      }

      .topbar {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 16px;
        margin-bottom: 20px;
      }

      .brand {
        margin: 0;
        font-size: 1.6rem;
        line-height: 1.1;
      }

      .tagline {
        margin: 6px 0 0;
        color: var(--muted);
      }

      .nav {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
      }

      .nav a {
        padding: 10px 14px;
        border-radius: 999px;
        border: 1px solid var(--line);
        background: var(--panel);
        box-shadow: var(--shadow);
        text-decoration: none;
      }

      .nav a.current {
        background: var(--panel-strong);
        font-weight: 700;
      }

      .notice,
      .panel {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 18px;
        box-shadow: var(--shadow);
      }

      .notice {
        padding: 14px 16px;
        margin-bottom: 20px;
        color: var(--muted);
      }

      .page-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 16px;
        margin-bottom: 18px;
      }

      .page-header h2,
      .page-header h3,
      .section-title {
        margin: 0;
      }

      .page-header p,
      .section-copy,
      .meta,
      .muted {
        color: var(--muted);
      }

      .section-copy,
      .page-header p,
      .meta {
        margin: 6px 0 0;
      }

      .grid {
        display: grid;
        gap: 18px;
      }

      .grid.two {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .panel {
        padding: 18px;
      }

      .stats {
        display: grid;
        gap: 14px;
        grid-template-columns: repeat(4, minmax(0, 1fr));
      }

      .stat {
        padding: 14px;
        border-radius: 14px;
        background: var(--panel-strong);
      }

      .stat .label {
        display: block;
        color: var(--muted);
        font-size: 0.86rem;
        margin-bottom: 8px;
      }

      .stat strong {
        font-size: 1rem;
      }

      .table-wrap {
        overflow-x: auto;
      }

      table {
        width: 100%;
        border-collapse: collapse;
      }

      th,
      td {
        padding: 14px 12px;
        text-align: left;
        border-bottom: 1px solid var(--line);
        vertical-align: top;
      }

      tr:last-child td {
        border-bottom: 0;
      }

      th {
        color: var(--muted);
        font-size: 0.82rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }

      .title-link {
        text-decoration: none;
        font-weight: 700;
      }

      .pill-row {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      .pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 10px;
        border-radius: 999px;
        font-size: 0.82rem;
        font-weight: 700;
      }

      .pill.ok {
        background: var(--ok-bg);
        color: var(--ok-text);
      }

      .pill.info {
        background: var(--info-bg);
        color: var(--info-text);
      }

      .pill.warn {
        background: var(--warn-bg);
        color: var(--warn-text);
      }

      .pill.danger {
        background: var(--danger-bg);
        color: var(--danger-text);
      }

      .pill.muted {
        background: var(--panel-strong);
        color: var(--muted);
      }

      .stack {
        display: grid;
        gap: 16px;
      }

      .actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
      }

      .button,
      button,
      select {
        border-radius: 12px;
        border: 1px solid var(--line);
        background: var(--panel);
        color: var(--text);
        font: inherit;
      }

      .button,
      button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        padding: 10px 14px;
        font-weight: 700;
      }

      form.filters {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        align-items: end;
      }

      .field {
        display: grid;
        gap: 6px;
      }

      .field label {
        color: var(--muted);
        font-size: 0.85rem;
      }

      select {
        min-width: 200px;
        padding: 10px 12px;
      }

      .empty {
        padding: 24px;
        text-align: center;
        color: var(--muted);
      }

      code {
        font-family: "SFMono-Regular", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 0.92em;
      }

      @media (max-width: 900px) {
        .grid.two,
        .stats {
          grid-template-columns: 1fr;
        }

        .topbar,
        .page-header {
          flex-direction: column;
        }
      }
    </style>
  </head>

  <body>
    <div class="shell">
      <header class="topbar">
        <div>
          <h1 class="brand">R3x Dashboard</h1>
          <p class="tagline">Workflow console for current runtime state and recent executions.</p>
        </div>

        <nav class="nav">
          <%= link_to "Workflows", workflows_path, class: current_page?(workflows_path) || current_page?(root_path) ? "current" : nil %>
          <%= link_to "Recent Runs", workflow_runs_path, class: current_page?(workflow_runs_path) ? "current" : nil %>
          <%= link_to "Mission Control", mission_control_path %>
        </nav>
      </header>

      <aside class="notice">
        Finished workflow runs are currently retained for <strong><%= finished_runs_retention_label %></strong>
        by the active <code>Solid Queue</code> setting. Retry, discard, and raw queue inspection stay in
        <%= link_to "Mission Control", mission_control_path %>.
      </aside>

      <%= yield %>
    </div>
  </body>
</html>

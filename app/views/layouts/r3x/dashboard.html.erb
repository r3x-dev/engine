<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for?(:title) ? yield(:title) : "R3x Dashboard" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <style>
      :root {
        color-scheme: light;
        --bg: #f6f8fa;
        --panel: #ffffff;
        --panel-subtle: #f6f8fa;
        --line: #d0d7de;
        --line-strong: #afb8c1;
        --text: #1f2328;
        --muted: #656d76;
        --accent: #0969da;
        --ok-bg: #dafbe1;
        --ok-text: #116329;
        --info-bg: #ddf4ff;
        --info-text: #0550ae;
        --warn-bg: #fff8c5;
        --warn-text: #7d4e00;
        --danger-bg: #ffebe9;
        --danger-text: #cf222e;
        --shadow: 0 1px 0 rgba(27, 31, 36, 0.04);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
      }

      a {
        color: inherit;
      }

      .shell {
        max-width: 1440px;
        margin: 0 auto;
        padding: 24px 28px 56px;
      }

      .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        padding-bottom: 14px;
        margin-bottom: 28px;
        border-bottom: 1px solid var(--line);
      }

      .brand-row {
        display: grid;
        gap: 4px;
      }

      .brand {
        margin: 0;
        font-size: 1.5rem;
        line-height: 1.1;
        letter-spacing: -0.02em;
      }

      .tagline,
      .section-copy,
      .page-header p,
      .meta,
      .muted,
      .notice {
        color: var(--muted);
      }

      .tagline {
        margin: 0;
        font-size: 0.92rem;
      }

      .nav,
      .toolbar,
      .actions,
      .pill-row {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        align-items: center;
      }

      .nav a,
      .button,
      button,
      select {
        border: 1px solid var(--line);
        background: var(--panel);
        color: var(--text);
        font: inherit;
        border-radius: 10px;
      }

      .nav a,
      .button,
      button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        min-height: 34px;
        padding: 6px 12px;
        text-decoration: none;
        font-weight: 500;
      }

      .nav a.current,
      .button.primary,
      button.primary {
        border-color: rgba(0, 0, 0, 0);
        background: var(--text);
        color: #ffffff;
      }

      .button.success,
      button.success {
        border-color: #1a7f37;
        background: #1a7f37;
        color: #ffffff;
      }

      .button.success:hover,
      button.success:hover {
        background: #166b2f;
        border-color: #166b2f;
      }

      .button.subtle,
      button.subtle {
        background: var(--panel-subtle);
      }

      .button.utility,
      .nav a.utility {
        border-color: transparent;
        background: transparent;
        color: var(--muted);
      }

      .button.utility:hover,
      .nav a.utility:hover {
        background: var(--panel-subtle);
        color: var(--text);
      }

      .notice,
      .panel {
        background: var(--panel);
        border: 1px solid var(--line);
        box-shadow: var(--shadow);
      }

      .notice {
        padding: 12px 14px;
        margin-bottom: 16px;
      }

      .panel {
        padding: 16px;
      }

      .page-header {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 16px;
        margin-bottom: 16px;
      }

      .page-header h2,
      .page-header h3,
      .section-title {
        margin: 0;
        letter-spacing: -0.02em;
      }

      .page-header p,
      .section-copy,
      .meta {
        margin: 4px 0 0;
      }

      .stats {
        display: grid;
        gap: 12px;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      }

      .stat {
        padding: 14px;
        background: var(--panel-subtle);
        border: 1px solid var(--line);
      }

      .stat .label {
        display: block;
        color: var(--muted);
        font-size: 0.75rem;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }

      .grid {
        display: grid;
        gap: 16px;
      }

      .grid.two {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .stack {
        display: grid;
        gap: 12px;
      }

      .table-wrap {
        overflow-x: auto;
      }

      table {
        width: 100%;
        border-collapse: collapse;
      }

      th,
      td {
        padding: 12px;
        text-align: left;
        border-bottom: 1px solid var(--line);
        vertical-align: top;
      }

      tr:last-child td {
        border-bottom: 0;
      }

      th {
        color: var(--muted);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }

      .title-link {
        text-decoration: none;
        font-weight: 600;
      }

      .title-link:hover {
        color: var(--accent);
      }

      .icon {
        display: inline-flex;
        width: 0.95rem;
        height: 0.95rem;
        flex: 0 0 0.95rem;
      }

      .icon svg {
        width: 100%;
        height: 100%;
      }

      .utility-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: var(--muted);
        font-size: 0.84rem;
        text-decoration: none;
      }

      .utility-link:hover {
        color: var(--text);
      }

      .pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 8px;
        font-size: 0.75rem;
        font-weight: 600;
        white-space: nowrap;
      }

      .pill.ok {
        background: var(--ok-bg);
        color: var(--ok-text);
      }

      .pill.info {
        background: var(--info-bg);
        color: var(--info-text);
      }

      .pill.warn {
        background: var(--warn-bg);
        color: var(--warn-text);
      }

      .pill.danger {
        background: var(--danger-bg);
        color: var(--danger-text);
      }

      .pill.muted {
        background: var(--panel-subtle);
        color: var(--muted);
      }

      form.filters {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        align-items: end;
      }

      .field {
        display: grid;
        gap: 6px;
      }

      .field label {
        color: var(--muted);
        font-size: 0.76rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }

      select {
        min-width: 220px;
        padding: 8px 10px;
      }

      .empty {
        padding: 24px;
        text-align: center;
        color: var(--muted);
      }

      .inline-form {
        display: inline-flex;
      }

      .inline-form button {
        min-height: 32px;
        padding: 6px 10px;
        font-size: 0.85rem;
      }

      code {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 0.92em;
      }

      .error-block {
        margin: 0;
        padding: 12px;
        overflow-x: auto;
        background: var(--panel-subtle);
        border: 1px solid var(--line);
        color: var(--text);
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 0.85rem;
        line-height: 1.5;
        white-space: pre-wrap;
        word-break: break-word;
      }

      .log-list {
        display: grid;
        border: 1px solid var(--line);
        background: var(--panel-subtle);
      }

      .log-entry {
        display: grid;
        gap: 6px;
        padding: 10px 12px;
      }

      .log-entry + .log-entry {
        border-top: 1px solid var(--line);
      }

      .log-meta {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        align-items: center;
        color: var(--muted);
        font-size: 0.84rem;
      }

      .log-message {
        color: var(--text);
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 0.85rem;
        line-height: 1.5;
        white-space: pre-wrap;
        word-break: break-word;
      }

      .logs-placeholder {
        position: relative;
        min-height: 240px;
        padding: 18px;
        overflow: hidden;
        border: 1px solid var(--line);
        background:
          linear-gradient(180deg, rgba(127, 127, 127, 0.06), rgba(127, 127, 127, 0.12)),
          var(--panel-subtle);
      }

      .logs-placeholder-preview {
        display: grid;
        gap: 12px;
        width: min(100%, 620px);
        opacity: 0.38;
        filter: blur(1.6px);
        pointer-events: none;
        user-select: none;
      }

      .logs-placeholder-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 14px;
        background: var(--panel);
        border: 1px solid var(--line);
        box-shadow: var(--shadow);
      }

      .logs-placeholder-chip {
        display: inline-flex;
        width: 68px;
        height: 10px;
        border-radius: 999px;
        background: var(--panel-subtle);
        flex: 0 0 auto;
      }

      .logs-placeholder-line {
        display: inline-flex;
        height: 10px;
        border-radius: 999px;
        background: var(--panel-subtle);
      }

      .logs-placeholder-line-short {
        width: 32%;
      }

      .logs-placeholder-line-medium {
        width: 54%;
      }

      .logs-placeholder-line-long {
        width: 74%;
      }

      .logs-placeholder-action {
        position: absolute;
        inset: 50% auto auto 50%;
        transform: translate(-50%, -50%);
        box-shadow: var(--shadow);
      }

      @media (max-width: 960px) {
        .grid.two,
        .stats {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 760px) {
        .shell {
          padding-inline: 14px;
        }

        .topbar,
        .page-header {
          flex-direction: column;
          align-items: stretch;
        }

        .toolbar,
        .nav,
        .actions,
        form.filters {
          width: 100%;
        }

        .nav a,
        .button,
        button,
        select {
          width: 100%;
        }
      }
    </style>
  </head>

  <body>
    <div class="shell">
      <header class="topbar">
        <div class="brand-row">
          <h1 class="brand"><%= link_to "R3x Dashboard", root_path, style: "text-decoration: none;" %></h1>
          <p class="tagline">Workflow runtime from the database</p>
        </div>

        <div class="toolbar">
          <nav class="nav">
            <%= link_to dashboard_icon_label(:workflow, "Workflows"), workflows_path, class: controller_name == "workflows" ? "current" : nil %>
            <%= link_to dashboard_icon_label(:history, "Recent Runs"), workflow_runs_path, class: controller_name == "workflow_runs" ? "current" : nil %>
          </nav>

          <%= link_to dashboard_icon_label(:tune, "Advanced queue controls"), mission_control_path, class: "utility-link" %>
        </div>
      </header>

      <% if notice.present? %>
        <aside class="notice"><strong>Queued:</strong> <%= notice %></aside>
      <% end %>

      <%= yield %>
    </div>
  </body>
</html>

<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for?(:title) ? yield(:title) : "R3x Dashboard" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <style>
      :root {
        color-scheme: light;
        --bg: #f6f8fa;
        --panel: #ffffff;
        --panel-subtle: #f6f8fa;
        --line: #d0d7de;
        --line-strong: #afb8c1;
        --text: #1f2328;
        --muted: #656d76;
        --accent: #0969da;
        --ok-bg: #dafbe1;
        --ok-text: #116329;
        --info-bg: #ddf4ff;
        --info-text: #0550ae;
        --warn-bg: #fff8c5;
        --warn-text: #7d4e00;
        --danger-bg: #ffebe9;
        --danger-text: #cf222e;
        --shadow: 0 1px 0 rgba(27, 31, 36, 0.04);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
      }

      a {
        color: inherit;
      }

      .shell {
        max-width: 1440px;
        margin: 0 auto;
        padding: 24px 28px 56px;
      }

      .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        padding-bottom: 14px;
        margin-bottom: 28px;
        border-bottom: 1px solid var(--line);
      }

      .brand-row {
        display: grid;
        gap: 4px;
      }

      .brand {
        margin: 0;
        font-size: 1.5rem;
        line-height: 1.1;
        letter-spacing: -0.02em;
      }

      .tagline,
      .section-copy,
      .page-header p,
      .meta,
      .muted,
      .notice {
        color: var(--muted);
      }

      .tagline {
        margin: 0;
        font-size: 0.92rem;
      }

      .nav,
      .toolbar,
      .actions,
      .pill-row {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        align-items: center;
      }

      .nav a,
      .button,
      button,
      select {
        border: 1px solid var(--line);
        background: var(--panel);
        color: var(--text);
        font: inherit;
        border-radius: 10px;
      }

      .nav a,
      .button,
      button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        min-height: 34px;
        padding: 6px 12px;
        text-decoration: none;
        font-weight: 500;
      }

      .nav a.current,
      .button.primary,
      button.primary {
        border-color: rgba(0, 0, 0, 0);
        background: var(--text);
        color: #ffffff;
      }

      .button.success,
      button.success {
        border-color: #1a7f37;
        background: #1a7f37;
        color: #ffffff;
      }

      .button.success:hover,
      button.success:hover {
        background: #166b2f;
        border-color: #166b2f;
      }

      .button.subtle,
      button.subtle {
        background: var(--panel-subtle);
      }

      .button.utility,
      .nav a.utility {
        border-color: transparent;
        background: transparent;
        color: var(--muted);
      }

      .button.utility:hover,
      .nav a.utility:hover {
        background: var(--panel-subtle);
        color: var(--text);
      }

      .notice,
      .panel {
        background: var(--panel);
        border: 1px solid var(--line);
        box-shadow: var(--shadow);
      }

      .notice {
        padding: 12px 14px;
        margin-bottom: 16px;
      }

      .panel {
        padding: 16px;
      }

      .page-header {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 16px;
        margin-bottom: 16px;
      }

      .page-header h2,
      .page-header h3,
      .section-title {
        margin: 0;
        letter-spacing: -0.02em;
      }

      .page-header p,
      .section-copy,
      .meta {
        margin: 4px 0 0;
      }

      .stats {
        display: grid;
        gap: 12px;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      }

      .stat {
        padding: 14px;
        background: var(--panel-subtle);
        border: 1px solid var(--line);
      }

      .stat .label {
        display: block;
        color: var(--muted);
        font-size: 0.75rem;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }

      .grid {
        display: grid;
        gap: 16px;
      }

      .grid.two {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .stack {
        display: grid;
        gap: 12px;
      }

      .table-wrap {
        overflow-x: auto;
      }

      table {
        width: 100%;
        border-collapse: collapse;
      }

      th,
      td {
        padding: 12px;
        text-align: left;
        border-bottom: 1px solid var(--line);
        vertical-align: top;
      }

      tr:last-child td {
        border-bottom: 0;
      }

      th {
        color: var(--muted);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }

      .title-link {
        text-decoration: none;
        font-weight: 600;
      }

      .title-link:hover {
        color: var(--accent);
      }

      .icon {
        display: inline-flex;
        width: 0.95rem;
        height: 0.95rem;
        flex: 0 0 0.95rem;
      }

      .icon svg {
        width: 100%;
        height: 100%;
      }

      .utility-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: var(--muted);
        font-size: 0.84rem;
        text-decoration: none;
      }

      .utility-link:hover {
        color: var(--text);
      }

      .pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 8px;
        font-size: 0.75rem;
        font-weight: 600;
        white-space: nowrap;
      }

      .pill.ok {
        background: var(--ok-bg);
        color: var(--ok-text);
      }

      .pill.info {
        background: var(--info-bg);
        color: var(--info-text);
      }

      .pill.warn {
        background: var(--warn-bg);
        color: var(--warn-text);
      }

      .pill.danger {
        background: var(--danger-bg);
        color: var(--danger-text);
      }

      .pill.muted {
        background: var(--panel-subtle);
        color: var(--muted);
      }

      form.filters {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        align-items: end;
      }

      .field {
        display: grid;
        gap: 6px;
      }

      .field label {
        color: var(--muted);
        font-size: 0.76rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }

      select {
        min-width: 220px;
        padding: 8px 10px;
      }

      .empty {
        padding: 24px;
        text-align: center;
        color: var(--muted);
      }

      .inline-form {
        display: inline-flex;
      }

      .inline-form button {
        min-height: 32px;
        padding: 6px 10px;
        font-size: 0.85rem;
      }

      code {
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 0.92em;
      }

      .error-block {
        margin: 0;
        padding: 12px;
        overflow-x: auto;
        background: var(--panel-subtle);
        border: 1px solid var(--line);
        color: var(--text);
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 0.85rem;
        line-height: 1.5;
        white-space: pre-wrap;
        word-break: break-word;
      }

      .log-list {
        display: grid;
        gap: 2px;
        border: 1px solid var(--line);
        background: var(--panel-subtle);
        padding: 10px 12px;
        overflow-x: auto;
      }

      .log-entry {
        display: flex;
        gap: 12px;
        align-items: start;
        min-width: 100%;
        width: max-content;
        color: var(--text);
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 0.85rem;
        line-height: 1.5;
      }

      .log-time {
        color: var(--muted);
        white-space: nowrap;
      }

      .log-message {
        white-space: pre;
      }

      .log-severity {
        min-width: 52px;
        justify-content: center;
        padding: 2px 8px;
        font-size: 0.7rem;
        line-height: 1.4;
      }

      .log-entry-danger .log-message {
        color: var(--danger-text);
      }

      .log-entry-warn .log-message {
        color: var(--warn-text);
      }

      .log-last-updated {
        display: inline-flex;
        align-items: center;
        min-height: 34px;
        margin: 0;
        white-space: nowrap;
      }

      .log-actions {
        justify-content: flex-end;
      }

      .log-live-indicator {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        min-height: 34px;
        padding: 0 10px;
        border: 1px solid var(--line);
        background: var(--panel-subtle);
        color: var(--muted);
        white-space: nowrap;
      }

      .log-live-dot {
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: currentColor;
        opacity: 0.7;
      }

      .log-live-label {
        font-weight: 600;
      }

      .log-live-ellipsis {
        display: inline-grid;
        grid-auto-flow: column;
        gap: 1px;
        min-width: 1.5em;
      }

      .log-live-ellipsis span {
        opacity: 0.25;
        animation: log-live-pulse 1.2s infinite ease-in-out;
      }

      .log-live-ellipsis span:nth-child(2) {
        animation-delay: 0.2s;
      }

      .log-live-ellipsis span:nth-child(3) {
        animation-delay: 0.4s;
      }

      .log-live-indicator[data-state="refreshing"] {
        color: var(--accent);
      }

      .log-live-indicator[data-state="paused"] {
        color: var(--warn-text);
      }

      @keyframes log-live-pulse {
        0%, 80%, 100% {
          opacity: 0.25;
        }

        40% {
          opacity: 1;
        }
      }

      .log-refresh-control {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        white-space: nowrap;
      }

      .log-refresh-select {
        min-width: 120px;
      }

      .log-refresh-state {
        display: inline-flex;
        align-items: center;
        min-height: 34px;
        margin: 0;
        white-space: nowrap;
      }

      @media (max-width: 960px) {
        .grid.two,
        .stats {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 760px) {
        .shell {
          padding-inline: 14px;
        }

        .topbar,
        .page-header {
          flex-direction: column;
          align-items: stretch;
        }

        .toolbar,
        .nav,
        .actions,
        form.filters {
          width: 100%;
        }

        .nav a,
        .button,
        button,
        select {
          width: 100%;
        }
      }
    </style>
  </head>

  <body>
    <div class="shell">
      <header class="topbar">
        <div class="brand-row">
          <h1 class="brand"><%= link_to "R3x Dashboard", root_path, style: "text-decoration: none;" %></h1>
          <p class="tagline">Workflow runtime from the database</p>
        </div>

        <div class="toolbar">
          <nav class="nav">
            <%= link_to dashboard_icon_label(:workflow, "Workflows"), workflows_path, class: controller_name == "workflows" ? "current" : nil %>
            <%= link_to dashboard_icon_label(:history, "Recent Runs"), workflow_runs_path, class: controller_name == "workflow_runs" ? "current" : nil %>
          </nav>

          <%= link_to dashboard_icon_label(:tune, "Advanced queue controls"), mission_control_path, class: "utility-link" %>
        </div>
      </header>

      <% if notice.present? %>
        <aside class="notice"><strong>Queued:</strong> <%= notice %></aside>
      <% end %>

      <%= yield %>
    </div>

    <script>
      (() => {
        const storageKey = "r3x.dashboard.runLogs.autoRefresh"
        const defaultOption = "30s"
        const intervalByOption = {
          off: null,
          "5s": 5000,
          "30s": 30000,
          "1m": 60000,
          "5m": 300000
        }
        const legacyOptionByValue = {
          on: "5s"
        }
        let timeoutId

        const panel = () => document.getElementById("run-logs")

        const normalizeOption = (value) => {
          if (Object.prototype.hasOwnProperty.call(intervalByOption, value)) return value
          if (Object.prototype.hasOwnProperty.call(legacyOptionByValue, value)) return legacyOptionByValue[value]
          return defaultOption
        }

        const currentOption = () => {
          try {
            return normalizeOption(localStorage.getItem(storageKey))
          } catch (_) {
            return defaultOption
          }
        }

        const setOption = (value) => {
          try {
            localStorage.setItem(storageKey, normalizeOption(value))
          } catch (_) {
          }
        }

        const refreshable = (element) => element?.dataset.r3xLogRefresh === "true" && element.dataset.r3xRunStatus === "running"

        const refreshInterval = () => intervalByOption[currentOption()]

        const setStatus = (message) => {
          const status = panel()?.querySelector("[data-r3x-log-refresh-status]")
          if (status) status.textContent = message
        }

        const setLastUpdated = () => {
          const label = panel()?.querySelector("[data-r3x-log-last-updated]")
          if (!label) return

          const latestTime = panel()?.querySelector(".log-entry:last-child .log-time time")?.textContent || "--:--:--"
          label.textContent = `Last updated ${latestTime}`
        }

        const setLiveState = (state) => {
          const indicator = panel()?.querySelector("[data-r3x-log-live-indicator]")
          if (!indicator) return

          indicator.dataset.state = state
        }

        const syncControls = () => {
          const currentPanel = panel()
          const select = currentPanel?.querySelector("[data-r3x-log-refresh-select]")
          if (!select) return

          const option = currentOption()
          select.value = option
          select.disabled = !refreshable(currentPanel)

          if (!refreshable(currentPanel)) {
            setLiveState("paused")
            setLastUpdated()
            setStatus("Run finished")
            return
          }

          if (option === "off") {
            setLiveState("paused")
            setLastUpdated()
            setStatus("Auto-refresh off")
            return
          }

          setLiveState("idle")
          setLastUpdated()
          setStatus(`Every ${option} while running`)
        }

        const stop = () => {
          clearTimeout(timeoutId)
          timeoutId = undefined
        }

        const schedule = () => {
          stop()

          if (!refreshable(panel())) return

          const interval = refreshInterval()
          if (!interval) return

          timeoutId = setTimeout(refresh, interval)
        }

        const refresh = async () => {
          const currentPanel = panel()
          if (!refreshable(currentPanel) || !refreshInterval()) return

          if (document.hidden) {
            setLiveState("idle")
            schedule()
            return
          }

          setLiveState("refreshing")
          setStatus("Refreshing...")

          try {
            const response = await fetch(currentPanel.dataset.r3xLogRefreshUrl, {
              headers: {
                "Accept": "text/html",
                "X-Requested-With": "XMLHttpRequest"
              }
            })

            if (!response.ok) throw new Error(`Refresh failed: ${response.status}`)

            currentPanel.outerHTML = await response.text()
            syncControls()

            if (refreshable(panel())) {
              schedule()
            }
          } catch (_) {
            setLiveState("paused")
            setStatus("Refresh failed; retrying")
            schedule()
          }
        }

        document.addEventListener("change", (event) => {
          const select = event.target.closest("[data-r3x-log-refresh-select]")
          if (!select) return

          stop()
          setOption(select.value)
          syncControls()

          if (refreshInterval()) {
            refresh()
          }
        })

        syncControls()
        schedule()
      })()
    </script>
  </body>
</html>

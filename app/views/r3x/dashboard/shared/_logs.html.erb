<section class="panel stack" style="margin-top: 18px;">
  <div class="page-header">
    <div>
      <h3 class="section-title"><%= local_assigns.fetch(:title) %></h3>
      <p class="section-copy"><%= local_assigns.fetch(:description) %></p>
    </div>

    <% if local_assigns[:refreshable] || (local_assigns[:action_label].present? && local_assigns[:action_path].present?) %>
      <div class="actions log-actions">
        <% if local_assigns[:refreshable] %>
          <button type="button" class="button subtle log-refresh-toggle" data-r3x-log-refresh-toggle aria-pressed="true">Auto-refresh: on</button>
          <span class="meta log-refresh-state" data-r3x-log-refresh-status>Every 5s while running</span>
        <% end %>

        <% if local_assigns[:action_label].present? && local_assigns[:action_path].present? %>
          <%= link_to local_assigns.fetch(:action_label), local_assigns.fetch(:action_path), class: "button subtle" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <% if !logs[:configured] %>
    <div class="empty">Configure <code>R3X_LOGS_PROVIDER</code> to enable dashboard log queries.</div>
  <% elsif logs[:error].present? %>
    <div class="empty">Log query failed: <%= logs[:error] %></div>
  <% elsif logs[:entries].empty? %>
    <div class="empty"><%= local_assigns.fetch(:empty_message) %></div>
  <% else %>
    <div class="log-list">
      <% logs[:entries].each do |entry| %>
        <div class="log-entry">
          <span class="log-time"><%= dashboard_log_time(entry[:time]) %></span>
          <span class="log-message"><%= entry[:message] %></span>
        </div>
      <% end %>
    </div>
  <% end %>
</section>

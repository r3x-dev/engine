<section class="panel stack" style="margin-top: 18px;">
  <div class="page-header">
    <div>
      <h3 class="section-title"><%= local_assigns.fetch(:title) %></h3>
      <p class="section-copy"><%= local_assigns.fetch(:description) %></p>
    </div>

    <% if local_assigns[:refreshable] %>
      <div class="actions log-actions">
        <div class="log-refresh-control">
          <select class="log-refresh-select" data-r3x-log-refresh-select aria-label="Auto-refresh">
            <option value="off">Off</option>
            <option value="5s">5s</option>
            <option value="30s" selected="selected">30s</option>
            <option value="1m">1m</option>
            <option value="5m">5m</option>
          </select>
        </div>
        <span class="meta log-refresh-state" data-r3x-log-refresh-status>Every 30s while running</span>
      </div>
    <% end %>
  </div>

  <% if !logs[:configured] %>
    <div class="empty">Configure <code>R3X_LOGS_PROVIDER</code> to enable dashboard log queries.</div>
  <% elsif logs[:error].present? %>
    <div class="empty">Log query failed: <%= logs[:error] %></div>
  <% elsif logs[:entries].empty? %>
    <div class="empty"><%= local_assigns.fetch(:empty_message) %></div>
  <% else %>
    <div class="log-list">
      <% logs[:entries].each do |entry| %>
        <div class="log-entry">
          <span class="log-time"><%= dashboard_log_time(entry[:time]) %></span>
          <span class="log-message"><%= entry[:message] %></span>
        </div>
      <% end %>
    </div>
  <% end %>
</section>

<% columns = local_assigns.fetch(:columns, %i[workflow result observed trigger open]) %>

<div class="table-wrap">
  <% if runs.empty? %>
    <div class="empty"><%= local_assigns.fetch(:empty_message, "No workflow runs match the current filters.") %></div>
  <% else %>
    <table>
      <thead>
        <tr>
          <% if columns.include?(:workflow) %>
            <th>Workflow</th>
          <% end %>
          <% if columns.include?(:result) %>
            <th>Result</th>
          <% end %>
          <% if columns.include?(:observed) %>
            <th>Observed</th>
          <% end %>
          <% if columns.include?(:trigger) %>
            <th>Trigger</th>
          <% end %>
          <% if columns.include?(:open) %>
            <th>Open</th>
          <% end %>
        </tr>
      </thead>

      <tbody>
        <% runs.each do |run| %>
          <tr>
            <% if columns.include?(:workflow) %>
              <td>
                <%= dashboard_workflow_link(run) %>
              </td>
            <% end %>

            <% if columns.include?(:result) %>
              <td>
                <%= dashboard_status_pill(run[:status], error: run[:error]) %>
                <% if run[:resumptions].to_i.positive? %>
                  <%= dashboard_pill("resumptions: #{run[:resumptions]}", "info") %>
                <% end %>
              </td>
            <% end %>

            <% if columns.include?(:observed) %>
              <td><%= dashboard_timestamp(run[:recorded_at]) %></td>
            <% end %>

            <% if columns.include?(:trigger) %>
              <td><code title="<%= run[:trigger_key] %>"><%= dashboard_run_trigger_label(run) %></code></td>
            <% end %>

            <% if columns.include?(:open) %>
              <td>
                <%= link_to "Open run", workflow_run_path(run[:job_id]), class: "button subtle" %>
              </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>

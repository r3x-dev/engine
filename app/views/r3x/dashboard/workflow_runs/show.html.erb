<% content_for :title, @run[:workflow_title] %>

<%
  trigger_key = @run[:trigger_key] || "manual/default"
%>

<section class="page-header">
  <div>
    <div class="run-heading">
      <h2 class="page-title">
        <% if @run[:known_workflow] %>
          <%= link_to @run[:workflow_title], workflow_path(@run[:workflow_key]), class: "title-link" %>
        <% else %>
          <%= @run[:workflow_title] %>
        <% end %>
      </h2>

      <span class="pill <%= dashboard_tone_for(@run[:status]) %>">
        <%= dashboard_status_label(@run[:status]) %>
      </span>
    </div>
  </div>

  <div class="actions">
    <% if @run[:known_workflow] && %w[failed finished].include?(@run[:status]) %>
      <%= form_with url: workflow_run_rerun_path(@run[:job_id]), method: :post, local: true, class: "inline-form" do |form| %>
        <%= form.button dashboard_icon_label(:launch, "Rerun"), class: "button success" %>
      <% end %>
    <% end %>

    <% if @run[:known_workflow] %>
      <%= link_to "Back to workflow", workflow_path(@run[:workflow_key]), class: "button subtle" %>
      <%= link_to "Workflow runs", workflow_runs_path(workflow: @run[:workflow_key]), class: "button subtle" %>
    <% else %>
      <%= link_to "Recent runs", workflow_runs_path, class: "button subtle" %>
    <% end %>
  </div>
</section>

<section class="panel stack panel-spaced">
  <div>
    <h3 class="section-title">Run Details</h3>
  </div>

  <div class="detail-grid">
    <div class="detail-item">
      <span class="label">Trigger</span>
      <strong><code><%= trigger_key %></code></strong>
    </div>

    <div class="detail-item">
      <span class="label">Enqueued</span>
      <strong><%= dashboard_absolute_timestamp(@run[:enqueued_at]) %></strong>
    </div>

    <% terminal_time = if @run[:finished_at].present?
                         @run[:finished_at]
                       elsif @run[:status] == "failed"
                         @run[:recorded_at]
                       end %>

    <% if terminal_time.present? %>
      <div class="detail-item">
        <span class="label">Finished</span>
        <strong><%= dashboard_absolute_timestamp(terminal_time) %></strong>
      </div>
    <% end %>

    <% if @run[:scheduled_at].present? %>
      <div class="detail-item">
        <span class="label">Scheduled</span>
        <strong><%= dashboard_absolute_timestamp(@run[:scheduled_at]) %></strong>
      </div>
    <% end %>

  </div>

  <details class="technical-details">
    <summary>Technical details</summary>

    <dl class="technical-grid">
      <div class="technical-item">
        <dt>Run ID</dt>
        <dd><code><%= @run[:job_id] %></code></dd>
      </div>
      <div class="technical-item">
        <dt>Class</dt>
        <dd><code><%= @run[:class_name] %></code></dd>
      </div>
      <% if @run[:active_job_id].present? %>
        <div class="technical-item">
          <dt>Active Job ID</dt>
          <dd><code><%= @run[:active_job_id] %></code></dd>
        </div>
      <% end %>
    </dl>
  </details>
</section>

<% if @run[:error].present? %>
  <section class="panel stack panel-spaced">
    <div>
      <h3 class="section-title">Failure Details</h3>
    </div>

    <pre class="error-block"><%= dashboard_error_body(@run[:error]) %></pre>
  </section>
<% end %>

<% if logs_configured? %>
  <%= render "r3x/dashboard/workflow_runs/logs_panel", run: @run, logs: @logs %>
<% end %>

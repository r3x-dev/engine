<% content_for :title, "Run #{ @run[:job_id] }" %>

<%
  primary_time_label = @run[:finished_at].present? ? "Finished" : "Recorded"
  primary_time_value = @run[:finished_at].presence || @run[:recorded_at]
%>

<section class="page-header">
  <div>
    <h2>Run <code><%= @run[:job_id] %></code></h2>
    <p>Detailed runtime view for a persisted workflow execution.</p>
  </div>

  <div class="actions">
    <% if @run[:known_workflow] && %w[failed finished].include?(@run[:status]) %>
      <%= form_with url: workflow_run_rerun_path(@run[:job_id]), method: :post, local: true, class: "inline-form" do |form| %>
        <%= form.button dashboard_icon_label(:launch, "Rerun"), class: "button success" %>
      <% end %>
    <% end %>

    <% if @run[:known_workflow] %>
      <%= link_to "Back to workflow", workflow_path(@run[:workflow_key]), class: "button subtle" %>
      <%= link_to "Workflow runs", workflow_runs_path(workflow: @run[:workflow_key]), class: "button subtle" %>
    <% else %>
      <%= link_to "Recent runs", workflow_runs_path, class: "button subtle" %>
    <% end %>
  </div>
</section>

<section class="panel">
  <div class="stats">
    <div class="stat">
      <span class="label">Workflow</span>
      <strong><%= @run[:workflow_title] %></strong>
    </div>

    <div class="stat">
      <span class="label">Status</span>
      <strong><%= dashboard_status_label(@run[:status]) %></strong>
    </div>

    <div class="stat">
      <span class="label">Queue</span>
      <strong><code><%= @run[:queue_name] %></code></strong>
    </div>

    <div class="stat">
      <span class="label"><%= primary_time_label %></span>
      <strong><%= dashboard_relative_time(primary_time_value) %></strong>
      <div class="meta"><%= dashboard_absolute_timestamp(primary_time_value) %></div>
    </div>
  </div>
</section>

<section class="panel stack panel-spaced">
  <div>
    <h3 class="section-title">Metadata</h3>
    <p class="section-copy">Only the details that help explain what this run was and when it happened.</p>
  </div>

  <div class="meta-grid">
    <section class="meta-card">
      <h4 class="meta-card-title">Run</h4>
      <dl class="meta-list">
        <div>
          <dt>Workflow</dt>
          <dd><%= dashboard_workflow_link(@run) %></dd>
        </div>
        <div>
          <dt>Trigger</dt>
          <dd><code><%= @run[:trigger_key] || "manual/default" %></code></dd>
        </div>
        <div>
          <dt>Job id</dt>
          <dd><code><%= @run[:job_id] %></code></dd>
        </div>
      </dl>
    </section>

    <section class="meta-card">
      <h4 class="meta-card-title">Timeline</h4>
      <dl class="meta-list">
        <div>
          <dt>Enqueued</dt>
          <dd><%= dashboard_absolute_timestamp(@run[:enqueued_at]) %></dd>
        </div>
        <% if @run[:scheduled_at].present? %>
          <div>
            <dt>Scheduled</dt>
            <dd><%= dashboard_absolute_timestamp(@run[:scheduled_at]) %></dd>
          </div>
        <% end %>
        <div>
          <dt>Recorded</dt>
          <dd><%= dashboard_absolute_timestamp(@run[:recorded_at]) %></dd>
        </div>
        <% if @run[:finished_at].present? %>
          <div>
            <dt>Finished</dt>
            <dd><%= dashboard_absolute_timestamp(@run[:finished_at]) %></dd>
          </div>
        <% end %>
      </dl>
    </section>
  </div>

  <details class="metadata-details">
    <summary>Technical details</summary>
    <dl class="meta-list compact">
      <div>
        <dt>Class</dt>
        <dd><code><%= @run[:class_name] %></code></dd>
      </div>
      <% if @run[:active_job_id].present? %>
        <div>
          <dt>Active Job id</dt>
          <dd><code><%= @run[:active_job_id] %></code></dd>
        </div>
      <% end %>
    </dl>
  </details>
</section>

<% if @run[:error].present? %>
  <section class="panel stack panel-spaced">
    <div>
      <h3 class="section-title">Failure Details</h3>
    </div>

    <pre class="error-block"><%= dashboard_error_body(@run[:error]) %></pre>
  </section>
<% end %>

<% if logs_configured? %>
  <%= render "r3x/dashboard/workflow_runs/logs_panel", run: @run, logs: @logs %>
<% end %>

<% content_for :title, "Runs" %>

<section class="page-header">
  <div>
    <h2>Runs</h2>
    <p>Visible runs in the current queue retention window.</p>
  </div>
</section>

<nav class="filter-chips" aria-label="Quick status filters">
  <%= link_to "All",
              dashboard_run_filter_path(status: nil, workflow_key: @workflow_filter),
              class: [ "chip-link", (@status_filter.blank? ? "current" : nil) ].compact.join(" ") %>
  <%= link_to "Failed",
              dashboard_run_filter_path(status: "failed", workflow_key: @workflow_filter),
              class: [ "chip-link", (@status_filter == "failed" ? "current" : nil) ].compact.join(" ") %>
  <%= link_to "Running",
              dashboard_run_filter_path(status: "running", workflow_key: @workflow_filter),
              class: [ "chip-link", (@status_filter == "running" ? "current" : nil) ].compact.join(" ") %>
</nav>

<section class="panel filters-panel">
  <%= form_with url: workflow_runs_path, method: :get, local: true, class: "filters" do |form| %>
    <div class="field">
      <%= form.label :workflow, "Workflow" %>
      <%= form.select :workflow,
                      options_for_select(@workflow_options.map { |workflow| [ workflow[:title], workflow[:workflow_key] ] }, @workflow_filter),
                      { include_blank: "All workflows" } %>
    </div>

    <div class="field">
      <%= form.label :status, "Status" %>
      <%= form.select :status,
                      options_for_select(@statuses.map { |value| [ dashboard_status_label(value), value ] }, @status_filter),
                      { include_blank: "All statuses" } %>
    </div>

    <div class="actions">
      <%= form.submit "Filter", class: "button" %>
      <%= link_to "Reset", workflow_runs_path, class: "button" %>
    </div>
  <% end %>
</section>

<section class="panel stack">
  <%= render "r3x/dashboard/workflow_runs/table",
             runs: @runs,
             columns: %i[workflow result observed trigger run_id open],
             empty_message: "No workflow runs match the current filters." %>
</section>

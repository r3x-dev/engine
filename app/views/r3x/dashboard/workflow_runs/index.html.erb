<% content_for :title, "Recent Runs" %>

<section class="page-header">
  <div>
    <h2>Recent Runs</h2>
    <p>Visible workflow runs from the current <code>Solid Queue</code> retention window.</p>
  </div>

  <div class="actions">
    <%= link_to "Workflows", workflows_path, class: "button" %>
    <%= link_to "Mission Control", mission_control_path, class: "button" %>
  </div>
</section>

<section class="panel" style="margin-bottom: 18px;">
  <%= form_with url: workflow_runs_path, method: :get, local: true, class: "filters" do |form| %>
    <div class="field">
      <%= form.label :workflow, "Workflow" %>
      <%= form.select :workflow,
                      options_for_select(@workflow_options.map { |workflow| [ workflow.workflow_key.titleize, workflow.workflow_key ] }, @workflow_filter),
                      { include_blank: "All workflows" } %>
    </div>

    <div class="field">
      <%= form.label :status, "Status" %>
      <%= form.select :status,
                      options_for_select(@statuses.map { |value| [ dashboard_status_label(value), value ] }, @status_filter),
                      { include_blank: "All statuses" } %>
    </div>

    <div class="actions">
      <%= form.submit "Filter", class: "button" %>
      <%= link_to "Reset", workflow_runs_path, class: "button" %>
    </div>
  <% end %>
</section>

<section class="panel stack">
  <%= render "r3x/dashboard/workflow_runs/table", runs: @runs %>
</section>

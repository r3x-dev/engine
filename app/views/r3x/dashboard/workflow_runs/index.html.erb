<% content_for :title, "Recent Runs" %>

<section class="page-header">
  <div>
    <h2>Recent Runs</h2>
    <p>Visible runs in the current queue retention window.</p>
  </div>

  <div class="actions">
    <% if @workflow_filter.present? %>
      <%= link_to "Back to workflow", workflow_path(@workflow_filter), class: "button subtle" %>
    <% else %>
      <%= link_to "All workflows", workflows_path, class: "button subtle" %>
    <% end %>
  </div>
</section>

<section class="panel filters-panel">
  <%= form_with url: workflow_runs_path, method: :get, local: true, class: "filters" do |form| %>
    <div class="field">
      <%= form.label :workflow, "Workflow" %>
      <%= form.select :workflow,
                      options_for_select(@workflow_options.map { |workflow| [ workflow[:title], workflow[:workflow_key] ] }, @workflow_filter),
                      { include_blank: "All workflows" } %>
    </div>

    <div class="field">
      <%= form.label :status, "Status" %>
      <%= form.select :status,
                      options_for_select(@statuses.map { |value| [ dashboard_status_label(value), value ] }, @status_filter),
                      { include_blank: "All statuses" } %>
    </div>

    <div class="actions">
      <%= form.submit "Filter", class: "button" %>
      <%= link_to "Reset", workflow_runs_path, class: "button" %>
    </div>
  <% end %>
</section>

<section class="panel stack">
  <%= render "r3x/dashboard/workflow_runs/table", runs: @runs, empty_message: "No workflow runs match the current filters." %>
</section>

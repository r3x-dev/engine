<% content_for :title, "Workflows" %>

<section class="page-header">
  <div>
    <h2>Workflows</h2>
    <p>Current workflows reconstructed from persisted runtime state, ordered for fast health checks.</p>
  </div>
</section>

<section id="workflows-catalog" class="panel table-wrap">
  <% if @workflows.empty? %>
    <div class="empty">No workflows are visible yet. They will appear here once recurring tasks or direct workflow runs are written to the database.</div>
  <% else %>
    <table>
      <thead>
        <tr>
          <th aria-sort="<%= dashboard_workflow_sort_aria("workflow", active_sort: @sort, active_direction: @direction) %>">
            <%= dashboard_workflow_sort_link("Workflow", "workflow", active_sort: @sort, active_direction: @direction) %>
          </th>
          <th aria-sort="<%= dashboard_workflow_sort_aria("health", active_sort: @sort, active_direction: @direction) %>">
            <%= dashboard_workflow_sort_link("Health", "health", active_sort: @sort, active_direction: @direction) %>
          </th>
          <th aria-sort="<%= dashboard_workflow_sort_aria("next_trigger", active_sort: @sort, active_direction: @direction) %>">
            <%= dashboard_workflow_sort_link("Next trigger", "next_trigger", active_sort: @sort, active_direction: @direction) %>
          </th>
          <th aria-sort="<%= dashboard_workflow_sort_aria("last_run", active_sort: @sort, active_direction: @direction) %>">
            <%= dashboard_workflow_sort_link("Last run", "last_run", active_sort: @sort, active_direction: @direction) %>
          </th>
          <th>Action</th>
        </tr>
      </thead>

      <tbody>
        <% @workflows.each do |workflow| %>
          <tr>
            <td>
              <%= link_to workflow[:title], workflow_path(workflow[:workflow_key]), class: "title-link" %>
              <div class="meta">
                <%= pluralize(workflow[:trigger_count], "persisted trigger") %>
              </div>
            </td>

            <td>
              <%= dashboard_health_pill(workflow[:health]) %>
            </td>

            <td><%= dashboard_optional_timestamp(workflow[:next_trigger_at], fallback: "Manual only") %></td>

            <td>
              <% if workflow[:last_run].present? %>
                <% last_run = workflow[:last_run] %>
                <%= link_to workflow_run_path(last_run[:job_id]) do %>
                  <%= dashboard_status_pill(last_run[:status], error: last_run[:error]) %>
                  <div class="meta"><%= dashboard_timestamp(last_run[:recorded_at]) %></div>
                <% end %>
              <% else %>
                <span class="muted">No runs yet</span>
              <% end %>
            </td>

            <td>
              <% if workflow[:run_now_available] %>
                <%= form_with url: runs_workflow_path(workflow[:workflow_key]), method: :post, local: true, class: "inline-form" do |form| %>
                  <%= form.button dashboard_icon_label(:launch, "Run now"), class: "button success" %>
                <% end %>
              <% else %>
                <span class="muted">Unavailable</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</section>

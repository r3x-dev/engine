<% content_for :title, @workflow[:title] %>

<nav class="breadcrumbs" aria-label="Breadcrumb">
  <%= link_to "Overview", root_path %>
  <span>/</span>
  <%= link_to "Workflows", workflows_path %>
  <span>/</span>
  <span aria-current="page"><%= @workflow[:title] %></span>
</nav>

<section class="page-header">
  <div>
    <h2 class="page-title"><%= @workflow[:title] %></h2>
    <p>Workflow drill-down built from persisted runs and trigger state.</p>
  </div>

  <div class="actions">
    <% if @workflow[:run_now_available] %>
      <%= form_with url: run_trigger_workflow_path(@workflow[:workflow_key]), method: :post, local: true, class: "inline-form" do |form| %>
        <%= form.button dashboard_icon_label(:launch, "Run now"), class: "button success" %>
      <% end %>
    <% end %>
    <%= link_to "View all runs", workflow_runs_path(workflow: @workflow[:workflow_key]), class: "button subtle" %>
    <% if @latest_failure.present? %>
      <%= link_to dashboard_icon_label(:alert, "Latest failure"), workflow_run_path(@latest_failure[:job_id]), class: "button subtle" %>
    <% end %>
  </div>
</section>

<section class="panel">
  <div class="stats">
    <div class="stat">
      <span class="label">Last result</span>
      <% if @workflow[:last_run].present? %>
        <strong>
          <span class="pill <%= dashboard_tone_for(@workflow[:last_run][:status]) %>">
            <%= dashboard_status_label(@workflow[:last_run][:status]) %>
          </span>
        </strong>
        <span class="meta"><%= dashboard_timestamp(@workflow[:last_run][:recorded_at]) %></span>
      <% else %>
        <strong>No runs yet</strong>
      <% end %>
    </div>

    <div class="stat">
      <span class="label">Last seen</span>
      <strong><%= @workflow[:last_seen_at].present? ? dashboard_timestamp(@workflow[:last_seen_at]) : "Never" %></strong>
    </div>

    <div class="stat">
      <span class="label">Next trigger</span>
      <strong><%= @workflow[:next_trigger_at].present? ? dashboard_timestamp(@workflow[:next_trigger_at]) : "Manual only" %></strong>
    </div>
  </div>
</section>

<section class="panel stack panel-spaced">
  <div>
    <h3 class="section-title">Triggers</h3>
    <p class="section-copy">Schedules and runtime state.</p>
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Trigger</th>
          <th>Next</th>
          <th>State</th>
        </tr>
      </thead>
      <tbody>
        <% @workflow[:trigger_entries].each do |trigger_entry| %>
          <% trigger_state = trigger_entry[:trigger_state] %>
          <tr>
            <td>
              <div><strong><%= dashboard_trigger_kind(trigger_entry) %></strong></div>
              <div class="meta"><code><%= dashboard_trigger_details(trigger_entry) %></code></div>
              <div class="pill-row trigger-badges">
                <% if trigger_entry[:change_detecting] %>
                  <span class="pill info">Change detecting</span>
                <% end %>
                <% if trigger_entry[:recurring_task].blank? %>
                  <span class="pill muted">Observed from runtime state</span>
                <% end %>
              </div>
            </td>

            <td><%= trigger_entry[:next_trigger_at].present? ? dashboard_timestamp(trigger_entry[:next_trigger_at]) : "Manual only" %></td>

            <td>
              <div class="pill-row">
                <span class="pill muted"><%= trigger_entry[:mode].to_s.humanize %></span>
                <% if trigger_entry[:queue_name].present? %>
                  <span class="pill muted">Queue <code><%= trigger_entry[:queue_name] %></code></span>
                <% end %>
              </div>

              <% if trigger_state.present? %>
                <div class="meta">Last checked <%= dashboard_timestamp(trigger_state.last_checked_at) %></div>
                <div class="meta">Last triggered <%= dashboard_timestamp(trigger_state.last_triggered_at) %></div>

                <% if trigger_state.last_error_at.present? %>
                  <div class="meta">Last error <%= dashboard_error_summary(trigger_state.last_error_message) %></div>
                <% end %>
              <% else %>
                <span class="muted">No persisted runtime state</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>

<section class="panel stack panel-spaced">
  <div class="page-header">
    <div>
      <h3 class="section-title">Recent runs</h3>
      <p class="section-copy">Newest 10 visible runs for this workflow.</p>
    </div>
  </div>

  <%= render "r3x/dashboard/workflow_runs/table",
             runs: @runs,
             columns: %i[result observed trigger open],
             empty_message: "No recent runs are visible for this workflow yet." %>
</section>

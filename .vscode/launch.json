{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "type": "ruby_lsp",
      "name": "Debug Workflow",
      "request": "launch",
      "program": "${workspaceFolder}/bin/workflow run ${file}",
      "env": {
        "BUNDLE_PATH": "${workspaceFolder}/.bundle"
      }
    },
    {
      "type": "ruby_lsp",
      "name": "Debug script",
      "request": "launch",
      "program": "ruby ${file}",
      "env": {
        "BUNDLE_PATH": "${workspaceFolder}/.bundle"
      }
    },
    {
      "type": "ruby_lsp",
      "name": "Debug test",
      "request": "launch",
      "program": "ruby -Itest ${relativeFile}",
      "env": {
        "BUNDLE_PATH": "${workspaceFolder}/.bundle"
      }
    },
    {
      "type": "ruby_lsp",
      "name": "Attach debugger",
      "request": "attach"
    }
  ]
}

# HashiCorp Vault connection for local development / test.
# In this app, `dotenv` loads `.env` automatically in development and test.

# Production only: Rails secret used for signed data and message verification.
# Generate one with: bin/rails secret
# SECRET_KEY_BASE=replace-with-a-long-random-secret

# Required: Vault base URL, for example:
# R3X_VAULT_ADDR=https://vault.example.internal

# Required: token with read access to the configured secret path.
# R3X_VAULT_TOKEN=replace-with-your-token

# Required: default path with env vars for R3X. This should be a path to a KV v2 secret, for example:
# R3X_VAULT_SECRETS_PATH=secret/data/env/r3x

# Optional: default timezone for schedule triggers that do not specify `timezone:`
# and whose cron string does not already embed a timezone.
# Accepts IANA names like `Europe/Paris` and Rails names like
# `Pacific Time (US & Canada)`.
# R3X_TIMEZONE=UTC

# Prometheus Configuration
# Optional: URL of your Prometheus server for metrics scraping.
# PROMETHEUS_URL=http://localhost:9090

# Healthchecks.io Configuration
# Optional: Base URL for Healthchecks.io ping endpoints.
# HEALTHCHECKS_IO_URL=https://hc-ping.com/your-uuid-here

# File-backed dashboard run logs
# Optional: enable the dashboard's local development file-backed logs provider.
# R3X_LOGS_PROVIDER=file_log
# Optional: override the workflow/job JSONL file read by the dashboard in development.
# Defaults to log/workflow_runs.<env>.jsonl.
# `file_log` is not intended for production deployments.
# R3X_WORKFLOW_LOG_PATH=/absolute/path/to/workflow_runs.development.jsonl
# Optional: rotate local workflow logs after N archived files and this many bytes per file.
# Defaults: 10 files, 52428800 bytes (50 MiB) each.
# R3X_WORKFLOW_LOG_ROTATION_COUNT=10
# R3X_WORKFLOW_LOG_ROTATION_SIZE_BYTES=52428800

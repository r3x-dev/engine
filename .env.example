# HashiCorp Vault connection for local development / test.
# In this app, `dotenv` loads `.env` automatically in development and test.

# Required: Vault base URL, for example:
# R3X_VAULT_ADDR=https://vault.example.internal

# Required: token with read access to the configured secret path.
# R3X_VAULT_TOKEN=replace-with-your-token

# Required: default path with env vars for R3X. This should be a path to a KV v2 secret, for example:
# R3X_VAULT_SECRET_PATH=secret/data/env/r3x

# Optional: example override if you want a different app/env-specific secret.
# R3X_VAULT_SECRET_PATH=secret/data/env/r3x-staging

# LLM Configuration
# Optional: Set to "true" to refresh LLM models from providers at startup.
# This fetches the latest model list from configured providers (e.g., Gemini).
# R3X_LLM_REFRESH_MODELS=true

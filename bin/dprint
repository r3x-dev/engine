#!/usr/bin/env bash
# Wrapper to run dprint directly or via mise if available

set -euo pipefail

if command -v dprint >/dev/null 2>&1; then
  exec dprint "$@"
elif command -v mise >/dev/null 2>&1; then
  exec mise exec -- dprint "$@"
else
  echo "Error: dprint is not installed. Please install it using 'mise install' or by installing dprint globally." >&2
  exit 127
fi

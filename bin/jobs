#!/usr/bin/env ruby

require_relative "../config/environment"
require "solid_queue/cli"

solid_queue_in_puma = ActiveModel::Type::Boolean.new.cast(ENV["SOLID_QUEUE_IN_PUMA"])
job_role = ENV.fetch("R3X_JOB_ROLE", "all")

if solid_queue_in_puma || job_role == "worker"
  R3x::Workflow::Boot.load!
elsif job_role == "all" || job_role == "scheduler"
  R3x::Workflow::Boot.load_and_schedule!
else
  raise ArgumentError, "Unsupported R3X_JOB_ROLE: #{job_role}"
end

SolidQueue::Cli.start(ARGV)

#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative "../config/environment"
require "thor"
require "signet/oauth_2/client"

class GoogleOAuthCLI < Thor
  def self.exit_on_failure? = true
  namespace :"google-oauth"

  desc "authorize", "Start OAuth2 authorization flow"
  option :project, type: :string, aliases: "-p", required: true, desc: "Project name (e.g. MYAPP)"
  option :scopes, type: :string, aliases: "-s", desc: "Comma-separated scope aliases (optional - will prompt if not provided)"
  def authorize
    project = options[:project]

    step("[Step 1] Loading client credentials...")

    client_id = fetch_env!("GOOGLE_CLIENT_ID_#{project}")
    success("Found GOOGLE_CLIENT_ID_#{project}")

    client_secret = fetch_env!("GOOGLE_CLIENT_SECRET_#{project}")
    success("Found GOOGLE_CLIENT_SECRET_#{project}")

    scope_aliases = if options[:scopes]&.strip&.present?
      options[:scopes]
    else
      interactive_scope_selection
    end

    scopes = scope_aliases.split(",").map(&:strip).map do |s|
      R3x::Client::GoogleAuth.resolve_scope(s)
    end

    puts ""
    puts "=== Google OAuth2 Authorization ==="
    puts ""
    puts "Project: #{project}"
    puts "Scopes:  #{scopes.join(', ')}"

    step("[Step 2] Generating authorization URL...")

    auth_client = Signet::OAuth2::Client.new(
      client_id:     client_id,
      client_secret: client_secret,
      redirect_uri:  "http://localhost",
      scope:         scopes,
      authorization_uri: "https://accounts.google.com/o/oauth2/auth"
    )

    auth_url = auth_client.authorization_uri.to_s

    puts ""
    puts "  Open this URL in your browser:"
    puts ""
    puts "  #{auth_url}"

    step("[Step 3] After granting access...")
    puts "  Google will redirect to a URL like:"
    puts "    http://localhost/?code=4/0AX4XfWh..."
    puts ""
    puts "  The browser may show a connection error — that's expected."
    puts "  Copy the full redirect URL from the browser address bar."

    puts ""
    print "  Paste the redirect URL: "
    redirect_url = $stdin.gets&.chomp

    if redirect_url.nil? || redirect_url.strip.empty?
      puts ""
      failure("No URL provided — aborting")
      abort
    end

    code = extract_code_from_url(redirect_url.strip)

    step("[Step 4] Exchanging code for tokens...")

    token_client = Signet::OAuth2::Client.new(
      client_id:     client_id,
      client_secret: client_secret,
      redirect_uri:  "http://localhost",
      code:          code,
      token_credential_uri: "https://oauth2.googleapis.com/token"
    )

    begin
      token_client.fetch_access_token!
    rescue Signet::AuthorizationError => e
      failure("Token exchange failed: #{e.message}")
      puts ""
      puts "  Make sure you copied the full authorization code."
      puts "  Re-run this command to try again."
      abort
    rescue StandardError => e
      failure("Unexpected error: #{e.class} — #{e.message}")
      abort
    end

    success("Access token obtained")

    refresh_token = token_client.refresh_token

    step("[Step 5] Store the refresh token in Vault")
    vault_key = "GOOGLE_REFRESH_TOKEN_#{project}"
    puts ""
    puts "  Vault key: #{vault_key}"
    puts ""
    puts "  #{refresh_token}"
    puts ""
    puts "  Run:"
    puts "  vault kv put secret/data/env/r3x #{vault_key}='#{refresh_token}'"
    puts ""
    puts "Done! Test with: bin/google-oauth status --project #{project}"
  end

  desc "status", "Check credential status for a project"
  option :project, type: :string, aliases: "-p", required: true, desc: "Project name (e.g. MYAPP)"
  def status
    project = options[:project]

    puts ""
    puts "=== Google OAuth2 Status ==="
    puts ""
    puts "Project: #{project}"

    step("[Step 1] Checking client credentials...")

    fetch_env!("GOOGLE_CLIENT_ID_#{project}")
    success("Found GOOGLE_CLIENT_ID_#{project}")

    fetch_env!("GOOGLE_CLIENT_SECRET_#{project}")
    success("Found GOOGLE_CLIENT_SECRET_#{project}")

    step("[Step 2] Checking refresh token...")

    refresh_token_key = "GOOGLE_REFRESH_TOKEN_#{project}"
    refresh_token = R3x::Env.fetch(refresh_token_key)

    unless refresh_token
      failure("Missing #{refresh_token_key}")
      puts ""
      puts "  Run authorization first:"
      puts "  bin/google-oauth authorize --project #{project} --scopes gmail.readonly,sheets.readonly"
      abort
    end

    success("Found #{refresh_token_key}")

    step("[Step 3] Validating refresh token...")

    begin
      R3x::Client::GoogleAuth.from_env(
        project: project,
        scope: "https://www.googleapis.com/auth/spreadsheets.readonly"
      )
      success("Token valid — access token obtained")
    rescue Signet::AuthorizationError => e
      failure("Token invalid: #{e.class} — #{e.message}")
      puts ""
      puts "  The refresh token may have expired or been revoked."
      puts "  Re-run: bin/google-oauth authorize --project #{project} --scopes gmail.readonly,sheets.readonly"
      abort
    rescue ArgumentError => e
      failure("Missing credential: #{e.message}")
      abort
    rescue StandardError => e
      failure("Unexpected error: #{e.class} — #{e.message}")
      abort
    end

    puts ""
    puts "Status: Ready"
  end

  desc "scopes", "List available scope aliases"
  def scopes
    puts ""
    puts "Available scope aliases:"
    R3x::Client::GoogleAuth.scope_aliases.each do |alias_name, const_name|
      scope = R3x::Client::GoogleAuth.resolve_scope(alias_name)
      puts "  %-24s %s" % [alias_name, scope]
    end
    puts ""
    puts "Example: --scopes gmail.readonly,sheets.readonly"
  end

  private

  def checkmark
    "  \e[32m✓\e[0m"
  end

  def crossmark
    "  \e[31m✗\e[0m"
  end

  def step(text)
    puts ""
    puts text
  end

  def success(text)
    puts "#{checkmark} #{text}"
  end

  def failure(text)
    puts "#{crossmark} #{text}"
  end

  def extract_code_from_url(url)
    uri = URI.parse(url)
    params = URI.decode_www_form(uri.query.to_s).to_h
    params["code"].presence || begin
      failure("No 'code' parameter found in the URL")
      puts ""
      puts "  Make sure you pasted the full redirect URL from the browser."
      puts "  Example: http://localhost/?code=4/0AX4XfWh..."
      abort
    end
  rescue URI::InvalidURIError => e
    failure("Invalid URL: #{e.message}")
    puts ""
    puts "  Make sure you pasted the full redirect URL from the browser."
    abort
  end

  def fetch_env!(key)
    R3x::Env.fetch(key) || begin
      failure("Missing #{key}")
      puts ""
      puts "  Set it in Vault at: secret/data/env/r3x"
      puts "  Key: #{key}"
      abort
    end
  end

  def interactive_scope_selection
    require "highline"

    cli = HighLine.new

    puts ""
    puts "=== Select Google API Scopes ==="
    puts ""

    aliases = R3x::Client::GoogleAuth.scope_aliases.keys
    selected_aliases = []

    loop do
      remaining = aliases - selected_aliases

      if remaining.empty?
        puts "All available scopes selected."
        break
      end

      puts "Available scopes (selected: #{selected_aliases.size}):"
      puts ""

        choice = cli.choose do |menu|
          menu.prompt = "Select a scope (or 'done' to finish): "

          remaining.each do |alias_name|
            scope = R3x::Client::GoogleAuth.resolve_scope(alias_name)
            menu.choice("#{alias_name} (#{scope})") { alias_name }
          end

          menu.choice(:all) { :all }
          menu.choice(:done) { nil }
        end

        break if choice.nil? || choice == :done

        if choice == :all
          selected_aliases.concat(remaining)
          break
        end

        selected_aliases << choice
      puts "  ✓ Added: #{choice}"
      puts ""

      break if (aliases - selected_aliases).empty?

      more = cli.ask("Add another scope? (y/n) ") { |q| q.default = "y" }
      break unless more.downcase.start_with?("y")
    end

    if selected_aliases.empty?
      puts ""
      puts "No scopes selected. Aborting."
      abort
    end

    puts ""
    puts "Selected scopes:"
    selected_aliases.each { |a| puts "  • #{a}" }

    confirm = cli.ask("Proceed with authorization? (y/n) ") { |q| q.default = "y" }

    unless confirm.downcase.start_with?("y")
      puts "Cancelled."
      abort
    end

    selected_aliases.join(",")
  end
end

GoogleOAuthCLI.start(ARGV)
